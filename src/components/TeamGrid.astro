---
const { members, isLead = false } = Astro.props;
---

<div class="team-grid">
  {members.map((member) => (
    <div class:list={['team-card', { 'lead-card': isLead }]}>
      <div class="avatar-wrapper">
        <img src={member.avatar} alt={member.name} />
      </div>
      <h3>{member.name}</h3>
      <p class="role">{member.role}</p>
    </div>
  ))}
</div>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin: 2rem 0 4rem;
    justify-content: center;
  }

  .team-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: transform 0.2s;
  }

  .team-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
  }

  .avatar-wrapper {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 1rem;
    border: 3px solid var(--white);
    box-shadow: var(--shadow-sm);
  }

  .avatar-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  .team-card h3 {
    margin: 0.5rem 0 0.25rem;
    font-size: 1.25rem;
  }

  .role {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lead-card {
    background: rgba(255, 255, 255, 0.8);
    border-color: var(--accent);
  }
</style>
