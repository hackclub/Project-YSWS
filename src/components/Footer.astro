---
const today = new Date();
import { REPOSITORY_URL } from '../consts';

// Fetch latest commit info from GitHub API at build time
let commitHash = '';
let commitMessage = '';
let commitDate = '';
let commitUrl = '';

try {
	const res = await fetch('https://api.github.com/repos/bluelightning26/cat-boogie/commits?per_page=1');
	if (res.ok) {
		const [latest] = await res.json();
		commitHash = latest.sha.slice(0, 7);
		commitMessage = latest.commit.message.split('\n')[0]; // first line only
		commitDate = new Date(latest.commit.committer.date).toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		});
		commitUrl = latest.html_url;
	}
} catch (e) {
	// silently fail — commit tracker just won't render
}
---

<footer>
	<p>Created with ♥ by <a href="https://github.com/bluelightning26" target="_blank">Dhyan</a> and <a href="https://github.com/ScapularSteam" target="_blank">David</a> @ <a href="https://hackclub.com">Hack Club</a></p>
	<p class="credits"><a href="/overview/credits">Credits</a></p>
	&copy; {today.getFullYear()} Hack Club. 501(c)(3) nonprofit (EIN: 81-2908499)
	{commitHash && (
		<div class="commit-tracker">
			<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" style="vertical-align: -2px;">
				<path fill="currentColor" d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.25a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"/>
			</svg>
			<a href={commitUrl} target="_blank" title={commitMessage}>
				<code>{commitHash}</code>
			</a>
			<span class="commit-msg">{commitMessage}</span>
			<span class="commit-date">{commitDate}</span>
		</div>
	)}

	<div class="social-links">
		<a href={REPOSITORY_URL} target="_blank">
			<span class="sr-only">Go to Astro's GitHub repo</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: rgba(248, 226, 185, 0.5);
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0 auto 0.5rem auto;
		max-width: none;
	}
	.credits {
		font-size: 0.9em;
	}
	.credits a {
		color: var(--text-muted);
		text-decoration: underline;
	}
	.credits a:hover {
		color: var(--accent);
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.commit-tracker {
		margin-top: 1em;
		font-size: 0.85em;
		color: rgb(var(--gray));
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	.commit-tracker code {
		background: rgba(0, 0, 0, 0.08);
		padding: 0.15em 0.4em;
		border-radius: 4px;
		font-size: 0.9em;
		font-family: monospace;
	}
	.commit-tracker a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.commit-tracker a:hover {
		text-decoration: underline;
		color: var(--accent);
	}
	.commit-msg {
		max-width: 250px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.commit-date {
		opacity: 0.7;
	}
	.commit-date::before {
		content: '·';
		margin-right: 0.3em;
	}
</style>
